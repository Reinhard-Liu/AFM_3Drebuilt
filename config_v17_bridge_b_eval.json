  "encoder_depth": 8,
  "num_heads": 8,
  "drop_rate": 0.1,
  "denoiser_hidden_dim": 256,
  "denoiser_depth": 6,
  "diffusion_steps": 1000,
  "lr": 0.0001,
  "bridge_lr": 0.0003,
  "weight_decay": 1e-05,
  "epochs": 4,
  "save_dir": "experiments/v17_bridge_b_sidechain_formal_eval/checkpoints",
