{
  "data_root": "auto",
  "img_size": 128,
  "num_frames": 10,
  "augment_rotation": false,
  "batch_size": 64,
  "num_workers": 4,
  "patch_size": 16,
  "temporal_patch_size": 2,
  "embed_dim": 512,
  "encoder_depth": 8,
  "num_heads": 8,
  "drop_rate": 0.1,
  "denoiser_hidden_dim": 256,
  "denoiser_depth": 6,
  "diffusion_steps": 1000,
  "model_type": "diffusion",
  "max_samples": 5120,
  "val_size": 256,
  "lr": 0.0001,
  "bridge_lr": 0.0003,
  "weight_decay": 1e-05,
  "epochs": 3,
  "save_dir": "experiments/v17_pred_count_eval/checkpoints",
  "log_interval": 1,
  "eval_ddim_steps": 100,
  "eval_samples_per_epoch": 100,
  "eval_full_interval": 1,
  "use_amp": true,
  "physics_guidance": true,
  "guidance_step_size": 0.002,
  "guidance_time_threshold": 500,
  "use_shape_guidance": false,
  "use_type_class_weights": true,
  "constraint_weight_s1": 0.0,
  "constraint_weight_s2": 0.3,
  "constraint_weight_s3": 0.3,
  "bond_length_weight": 1.5,
  "use_v17_bridge_gt_scaffold_tokens": true,
  "v17_return_bridge_labels": true,
  "use_v17_bridge_predicted_relation_tokens": true,
  "v17_relation_token_teacher_force_prob": 0.0,
  "v17_scaffold_cross_attn_every": 2,
  "v17_scaffold_cross_attn_scale": 0.1,
  "v17_max_attachment_tokens": 24,
  "v17_max_sidechain_tokens": 48,
  "v17_include_sidechain_tokens": true,
  "v17_max_graph_depth": 8,
  "v17_scaffold_aux_weight": 0.2,
  "v17_structure_count_aux_weight": 0.2,
  "v17_structure_ring_system_loss_weight": 1.0,
  "v17_structure_scaffold_atom_loss_weight": 1.0,
  "v17_structure_non_scaffold_loss_weight": 2.0,
  "v17_structure_anchor_loss_weight": 1.0,
  "v17_structure_sidechain_edge_loss_weight": 2.0,
  "v17_scaffold_count_compensation": true,
  "v17_count_comp_source": "hybrid",
  "v17_count_comp_mode": "blend",
  "v17_count_comp_blend_alpha": 0.6,
  "v17_count_comp_hybrid_alpha": 0.25,
  "v17_count_comp_sidechain_ratio": 1.0,
  "v17_count_comp_pred_non_scaffold_ratio": 0.9,
  "v17_count_comp_pred_edge_ratio": 0.6,
  "v17_count_comp_relation_ratio": 0.4,
  "v17_count_comp_bias": 0.0,
  "v17_count_comp_external_mode": "max",
  "v17_count_comp_use_relation_signal": true,
  "v17_count_comp_valid_threshold": 0.5,
  "bridge_train_mode": "bridge_only",
  "bridge_eval_use_gt_scaffold_tokens": true,
  "bridge_eval_use_predicted_relation_tokens": true,
  "bridge_eval_use_gt_scaffold_soft_constraint": true,
  "bridge_eval_scaffold_constraint_time_threshold": 150,
  "bridge_eval_scaffold_constraint_scale": 0.08,
  "bridge_eval_scaffold_plane_scale": 0.04,
  "bridge_eval_scaffold_edge_scale": 0.12,
  "bridge_eval_scaffold_sidechain_edge_scale": 0.15,
  "bridge_eval_scaffold_post_guidance_scale": 0.0
}
