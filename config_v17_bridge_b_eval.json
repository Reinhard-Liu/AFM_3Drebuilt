{
  "data_root": "auto",
  "param_key": "K-1",
  "img_size": 128,
  "num_frames": 10,
  "min_corrugation": 1.25,
  "require_ring": true,
  "augment_rotation": false,
  "batch_size": 64,
  "num_workers": 4,
  "max_samples": 4096,
